generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  name         String?
  language     Language      @default(TR)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  company      Company?
  subscription Subscription?
}

model Company {
  id              String      @id @default(uuid())
  userId          String      @unique
  name            String
  address         String?
  city            String?
  country         String?
  taxId           String?
  vatId           String?
  email           String?
  phone           String?
  logoUrl         String?
  bankName        String?
  iban            String?
  swift           String?
  defaultTemplate String      @default("classic-standard")
  defaultCurrency Currency    @default(EUR)
  defaultLanguage Language    @default(TR)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  clients         Client[]
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices        Invoice[]
  products        Product[]
  recurring       Recurring[]
}

model Client {
  id                String    @id @default(uuid())
  companyId         String
  name              String
  address           String?
  city              String?
  country           String?
  vatId             String?
  email             String?
  phone             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  preferredLanguage Language?
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices          Invoice[]
}

model Product {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  description String?
  unit        String?
  unitPrice   Decimal  @default(0)
  vatRate     Decimal  @default(20)
  currency    Currency @default(EUR)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Invoice {
  id         String        @id @default(uuid())
  companyId  String
  clientId   String?
  number     String
  type       DocumentType  @default(INVOICE)
  status     InvoiceStatus @default(DRAFT)
  issueDate  DateTime      @default(now())
  dueDate    DateTime?
  currency   Currency      @default(EUR)
  language   Language      @default(TR)
  template   String        @default("classic-standard")
  themeColor String        @default("blue")
  taxMode    TaxMode       @default(NORMAL)
  qrMode     QrMode        @default(VERIFY)
  notes      String?
  subtotal   Decimal       @default(0)
  discount   Decimal       @default(0)
  vatTotal   Decimal       @default(0)
  total      Decimal       @default(0)
  gibNo      String?
  ettn       String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  client     Client?       @relation(fields: [clientId], references: [id])
  company    Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items      InvoiceItem[]
  payments   Payment[]

  @@unique([companyId, number])
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  unit        String?
  quantity    Decimal @default(1)
  unitPrice   Decimal @default(0)
  vatRate     Decimal @default(20)
  amount      Decimal @default(0)
  order       Int     @default(0)
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Payment {
  id        String   @id @default(uuid())
  invoiceId String
  amount    Decimal
  currency  Currency @default(EUR)
  method    String?
  paidAt    DateTime @default(now())
  note      String?
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Recurring {
  id           String   @id @default(uuid())
  companyId    String
  name         String
  active       Boolean  @default(true)
  frequency    String
  nextRun      DateTime
  templateData Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                   String    @id @default(uuid())
  userId               String    @unique
  plan                 Plan      @default(FREE)
  status               String    @default("active")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  iyzicoSubscriptionId String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Plan {
  FREE
  STARTER
  PRO
  BUSINESS
}

enum DocumentType {
  INVOICE
  PROFORMA
  COMMERCIAL
  QUOTE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum Currency {
  EUR
  USD
  GBP
  TRY
}

enum Language {
  TR
  EN
  DE
  NL
  FR
  ES
  IT
}

enum TaxMode {
  NORMAL
  REVERSE
  EXEMPT
}

enum QrMode {
  VERIFY
  PAY
  OFF
}
